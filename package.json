{
	"name": "pi-treex",
	"version": "0.1.0",
	"description": "Enhances pi's native /tree with sticky-left view and a detail pane",
	"type": "module",
	"main": "./treex.js",
	"files": ["treex.js", "src", "README.md", "LICENSE"],
	"keywords": ["pi-package"],
	"pi": {
		"extensions": ["./treex.js"]
	},
	"scripts": {
		"check": "biome check . && node --test",
		"format": "biome format --write .",
		"test": "node --test"
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*"
	}
}
